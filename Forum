<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>GSMFIX Forum - মোবাইল সার্ভিসিং কমিউনিটি</title>
  <style>
    /* 🔹 GSMFIX BLACK & ORANGE THEME */
    :root {
      --orange: #ff6a00;
      --orange-dark: #e55d00;
      --orange-light: #ff8533;
      --black: #080808;
      --dark-bg: #111111;
      --card-bg: #181818;
      --card-hover: #222222;
      --text-main: #f2f2f2;
      --text-muted: #9ca3af;
      --border: #2a2a2a;
      --border-light: #333333;
      --success: #22c55e;
      --warning: #eab308;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', 'Noto Sans Bengali', Tahoma, sans-serif;
      background: var(--black);
      color: var(--text-main);
      line-height: 1.6;
    }
    
    a { text-decoration: none; color: inherit; }
    
    /* 🔸 Navbar */
    .navbar {
      position: fixed; top: 0; width: 100%;
      background: var(--dark-bg);
      border-bottom: 3px solid var(--orange);
      box-shadow: 0 4px 20px rgba(255,106,0,0.15);
      z-index: 1000; padding: 0 1rem;
    }
    .nav-container {
      max-width: 1200px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; height: 64px;
    }
    .logo { display: flex; align-items: center; gap: 0.5rem; }
    .logo-badge {
      background: var(--orange); color: var(--black);
      padding: 0.45rem 1rem; border-radius: 0.5rem;      font-weight: 800; font-size: 1.2rem; letter-spacing: 0.5px;
    }
    .logo-text { font-weight: 600; color: var(--text-main); display: none; }
    @media(min-width: 768px) { .logo-text { display: inline; } }

    .nav-links { display: none; align-items: center; gap: 1.5rem; }
    @media(min-width: 768px) { .nav-links { display: flex; } }
    .nav-links a { font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--orange); }

    .auth-buttons { display: flex; gap: 0.75rem; }
    .btn {
      padding: 0.5rem 1.25rem; border-radius: 0.5rem;
      font-weight: 600; cursor: pointer; border: 2px solid transparent;
      transition: all 0.2s; font-size: 0.9rem;
    }
    .btn-outline { border-color: var(--orange); color: var(--orange); background: transparent; }
    .btn-outline:hover { background: var(--orange); color: var(--black); }
    .btn-primary { background: var(--orange); color: var(--black); box-shadow: 0 2px 8px rgba(255,106,0,0.4); }
    .btn-primary:hover { background: var(--orange-dark); transform: translateY(-1px); }

    .mobile-toggle {
      display: block; background: none; border: none;
      font-size: 1.5rem; color: var(--text-main); cursor: pointer;
    }
    @media(min-width: 768px) { .mobile-toggle { display: none; } }
    .mobile-menu { display: none; padding: 1rem; background: var(--dark-bg); border-top: 1px solid var(--border); }
    .mobile-menu.active { display: block; }
    .mobile-menu a { display: block; padding: 0.75rem 0; border-bottom: 1px solid var(--border); }

    /* 🔸 Main Container */
    .container { max-width: 1200px; margin: 0 auto; padding: 1rem; padding-top: 84px; }

    /* 🔸 Hero Section */
    .hero {
      background: linear-gradient(135deg, var(--black), #1a0d00);
      border: 1px solid var(--border-light);
      border-left: 4px solid var(--orange);
      border-radius: 1rem; padding: 2rem; margin-bottom: 2rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    }
    .hero h1 { font-size: 1.75rem; margin-bottom: 0.5rem; color: var(--text-main); }
    .hero p { opacity: 0.85; margin-bottom: 1rem; color: var(--text-muted); }
    .hero-stats { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .hero-stats span {
      background: rgba(255,106,0,0.15); color: var(--orange);
      padding: 0.4rem 1rem; border-radius: 2rem; font-size: 0.85rem;
      border: 1px solid rgba(255,106,0,0.3);
    }
    /* 🔸 Grid Layout */
    .forum-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    @media(min-width: 1024px) { .forum-grid { grid-template-columns: 2fr 1fr; } }

    .section-title {
      font-size: 1.5rem; font-weight: 700; color: var(--text-main);
      margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;
    }
    .section-title::before {
      content: ""; width: 4px; height: 2rem;
      background: var(--orange); border-radius: 2px;
    }

    /* 🔸 Category Cards */
    .categories-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-bottom: 2rem; }
    @media(min-width: 640px) { .categories-grid { grid-template-columns: repeat(2, 1fr); } }
    
    .category-card {
      background: var(--card-bg); border-radius: 0.75rem; padding: 1.25rem;
      border: 1px solid var(--border); display: flex; gap: 1rem;
      transition: all 0.25s; position: relative; overflow: hidden;
    }
    .category-card:hover {
      transform: translateY(-3px); border-color: var(--orange);
      box-shadow: 0 6px 18px rgba(255,106,0,0.15);
    }
    .category-icon {
      width: 3rem; height: 3rem; border-radius: 0.5rem;
      background: #222; color: var(--orange);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem; flex-shrink: 0; border: 1px solid var(--border);
    }
    .category-info h3 { font-weight: 600; font-size: 1.1rem; margin-bottom: 0.25rem; }
    .category-info p { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.5rem; }
    .category-meta { display: flex; gap: 1rem; font-size: 0.85rem; color: var(--text-muted); }

    /* 🔸 Thread List */
    .thread-list { background: var(--card-bg); border-radius: 0.75rem; border: 1px solid var(--border); overflow: hidden; }
    .thread-item {
      padding: 1rem; border-bottom: 1px solid var(--border);
      display: grid; grid-template-columns: auto 1fr auto; gap: 1rem; align-items: start;
    }
    .thread-item:last-child { border-bottom: none; }
    .thread-item:hover { background: var(--card-hover); }

    .thread-avatar {
      width: 2.5rem; height: 2.5rem; border-radius: 50%;
      background: linear-gradient(135deg, #333, #555); color: var(--orange);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.9rem; border: 2px solid var(--border);    }

    .thread-content h4 { font-weight: 600; margin-bottom: 0.25rem; }
    .thread-content h4 a:hover { color: var(--orange); }
    .thread-meta { display: flex; align-items: center; gap: 0.75rem; font-size: 0.8rem; color: var(--text-muted); flex-wrap: wrap; }
    .thread-tag { background: #2a2a2a; padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-size: 0.75rem; color: var(--text-muted); }
    .thread-tag.pinned { background: #2a1f00; color: var(--orange); border: 1px solid rgba(255,106,0,0.4); }
    .thread-tag.solved { background: #0a2000; color: var(--success); border: 1px solid rgba(34,197,94,0.4); }

    .thread-stats { text-align: right; font-size: 0.85rem; color: var(--text-muted); min-width: 80px; }
    .thread-stats strong { display: block; color: var(--text-main); font-size: 1.1rem; }

    /* 🔸 Sidebar */
    .sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
    .sidebar-card { background: var(--card-bg); border-radius: 0.75rem; padding: 1.25rem; border: 1px solid var(--border); }
    .sidebar-card h3 { font-weight: 600; margin-bottom: 1rem; color: var(--text-main); font-size: 1.1rem; }

    .stat-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--border); font-size: 0.9rem; }
    .stat-row:last-child { border-bottom: none; }
    .stat-row span:last-child { font-weight: 600; color: var(--orange); }

    .contributor-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem; border-radius: 0.5rem; transition: background 0.2s; }
    .contributor-item:hover { background: var(--card-hover); }
    .contributor-avatar {
      width: 2rem; height: 2rem; border-radius: 50%;
      background: #333; color: var(--orange); display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.8rem; border: 1px solid var(--border);
    }
    .contributor-name { font-weight: 500; font-size: 0.9rem; }
    .contributor-points { font-size: 0.8rem; color: var(--text-muted); }

    .quick-links a { display: block; padding: 0.4rem 0; color: var(--text-muted); transition: all 0.2s; }
    .quick-links a:hover { color: var(--orange); padding-left: 0.25rem; }

    /* 🔸 Footer */
    footer { background: var(--black); color: var(--text-muted); text-align: center; padding: 2rem 1rem; margin-top: 3rem; border-top: 3px solid var(--orange); }
    footer .brand { color: var(--orange); font-weight: 800; font-size: 1.2rem; margin-bottom: 0.5rem; letter-spacing: 1px; }
    footer p { margin: 0.25rem 0; }

    /* 🔸 Utility & Badges */
    .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 1rem; font-size: 0.75rem; font-weight: 600; }
    .badge-newbie { background: #222; color: #999; }
    .badge-apprentice { background: #222; color: var(--orange-light); border: 1px solid rgba(255,133,51,0.3); }
    .badge-technician { background: #1a1a1a; color: #4ade80; border: 1px solid rgba(74,222,128,0.3); }
    .badge-expert { background: #2a2200; color: #facc15; border: 1px solid rgba(250,204,21,0.3); }
    .badge-master { background: var(--orange); color: var(--black); }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: var(--black); }    ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--orange); }
  </style>
</head>
